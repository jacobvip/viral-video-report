# Viral Video Report — environment config
# Copy to .env and fill in. NEVER commit real secrets.
# Load before running, e.g.:  set -a; source .env; set +a

# --- Resend (delivery) ------------------------------------------------------
# Required for a live send. Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Sender. Default is Resend's test sender, which can ONLY deliver to the email
# that owns your Resend account. Swap to a verified-domain address to send to
# anyone (see README).
BRIEF_FROM=onboarding@resend.dev

# Comma-separated recipient list.
BRIEF_TO=kanyeshrayz@gmail.com

# Set to 1 to build the HTML but skip the actual send (safe testing). Unset/0 = live send.
BRIEF_DRY_RUN=1

# Optional subject override. If unset, derived as "Viral Video Report — Weekday, Month D, YYYY".
# BRIEF_SUBJECT=
